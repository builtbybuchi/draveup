{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "prebuild": "pnpm run db:generate",
    "build": "node ./build.mjs",
    "start": "node --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:sync": "node scripts/db-sync.mjs",
    "db:sync:force": "node scripts/db-sync.mjs --force",
    "db:seed-currencies": "node --env-file-if-exists=.env scripts/seed-currencies.mjs",
    "promote-admin": "node --env-file-if-exists=.env scripts/promote-admin.mjs",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "node scripts/db-studio.mjs",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@clerk/express": "^2.0.8",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@upstash/redis": "^1.38.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "nodejs-dna": "^1.0.3",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "prisma": "^7.6.0",
    "svix": "^1.89.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
